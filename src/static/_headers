# Cloudflare Pages headers. Applies to static assets (Functions set their own).
# Copied to the site root via the src/static passthrough in eleventy.config.js.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: https://*.githubusercontent.com; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://giscus.app; frame-src https://giscus.app; connect-src 'self' https://giscus.app; font-src 'self'; form-action 'self'

# Long-cache immutable assets (content rarely changes; safe to cache hard).
/*.png
  Cache-Control: public, max-age=31536000, immutable
/*.svg
  Cache-Control: public, max-age=31536000, immutable
/*.webp
  Cache-Control: public, max-age=31536000, immutable
/*.jpg
  Cache-Control: public, max-age=31536000, immutable

# CSS/JS filenames are unhashed, so always revalidate (cheap 304 via ETag) —
# users never get stale styles/scripts after a deploy.
/css/*
  Cache-Control: public, no-cache
/*.js
  Cache-Control: public, no-cache
